# ─── Site ────────────────────────────────────────────────────────────────────
# Canonical origin used in sitemap, robots.txt, and og:image URLs.
# Must NOT have a trailing slash. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
# All optional: without them the app runs fully anonymous-local
# (fs content + localStorage progress). For local dev: `pnpm db:start`, then
# `pnpm exec supabase status -o env` prints the values.

# Safe for the client bundle (anon key is RLS-gated).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server/scripts ONLY (content:seed). Never expose to the client bundle;
# never commit. CI provides it as a job secret.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
